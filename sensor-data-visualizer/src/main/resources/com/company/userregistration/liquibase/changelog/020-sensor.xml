<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="sensor-1" author="sensorviz" context="!cuba">
        <createTable tableName="SENSOR">
            <column name="ID" type="${uuid.type}">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="VERSION" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="NAME" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="MQTT_TOPIC" type="varchar(512)">
                <constraints nullable="false"/>
            </column>
            <column name="LAST_TEMPERATURE" type="double"/>
            <column name="LAST_RECORDED_AT" type="timestamp"/>
        </createTable>
    </changeSet>

    <changeSet id="sensor-2" author="sensorviz" context="!cuba">
        <createIndex indexName="IDX_SENSOR_ON_MQTT_TOPIC" tableName="SENSOR" unique="true">
            <column name="MQTT_TOPIC"/>
        </createIndex>
    </changeSet>

    <changeSet id="sensor-3" author="sensorviz" context="!cuba">
        <createTable tableName="SENSOR_READING">
            <column name="ID" type="${uuid.type}">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="VERSION" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="SENSOR_ID" type="${uuid.type}">
                <constraints nullable="false"/>
            </column>
            <column name="MEASURED_AT" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="TEMPERATURE" type="double">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="sensor-4" author="sensorviz" context="!cuba">
        <addForeignKeyConstraint baseTableName="SENSOR_READING"
                                 baseColumnNames="SENSOR_ID"
                                 constraintName="FK_SENSOR_READING_ON_SENSOR"
                                 referencedTableName="SENSOR"
                                 referencedColumnNames="ID"/>
        <createIndex indexName="IDX_SENSOR_READING_ON_SENSOR_TIME" tableName="SENSOR_READING">
            <column name="SENSOR_ID"/>
            <column name="MEASURED_AT"/>
        </createIndex>
    </changeSet>

    <changeSet id="sensor-5" author="sensorviz" context="!cuba">
        <insert tableName="SENSOR" dbms="postgresql, mssql, hsqldb">
            <column name="ID" value="a1111111-1111-4111-8111-111111111111"/>
            <column name="VERSION" value="1"/>
            <column name="NAME" value="Demo temperature sensor"/>
            <column name="MQTT_TOPIC" value="sensors/demo/temperature"/>
        </insert>
        <insert tableName="SENSOR" dbms="oracle, mysql, mariadb">
            <column name="ID" value="a111111111114111811111111111111"/>
            <column name="VERSION" value="1"/>
            <column name="NAME" value="Demo temperature sensor"/>
            <column name="MQTT_TOPIC" value="sensors/demo/temperature"/>
        </insert>
        <insert tableName="SENSOR" dbms="h2">
            <column name="ID" value="a1111111-1111-4111-8111-111111111111"/>
            <column name="VERSION" value="1"/>
            <column name="NAME" value="Demo temperature sensor"/>
            <column name="MQTT_TOPIC" value="sensors/demo/temperature"/>
        </insert>
    </changeSet>

</databaseChangeLog>
